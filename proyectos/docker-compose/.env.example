# PassProtect — Variables de entorno para Docker Compose
# Copiar a .env y rellenar los valores reales
# O usar scripts/setup/generate-secrets.sh para generar automaticamente

VPS_IP=TU_IP_VPS
VW_DOMAIN=https://vault.TU_IP_VPS.nip.io
KC_HOSTNAME=auth.TU_IP_VPS.nip.io

VW_ADMIN_TOKEN=CAMBIAR
DB_VW_ROOT_PASSWORD=CAMBIAR
DB_VW_NAME=vaultwarden
DB_VW_USER=vaultwarden
DB_VW_PASSWORD=CAMBIAR

KC_ADMIN=admin
KC_ADMIN_PASSWORD=CAMBIAR
DB_KC_ROOT_PASSWORD=CAMBIAR
DB_KC_NAME=keycloak
DB_KC_USER=keycloak
DB_KC_PASSWORD=CAMBIAR

SSO_CLIENT_ID=vaultwarden
SSO_CLIENT_SECRET=CAMBIAR
SSO_AUTHORITY=https://auth.TU_IP_VPS.nip.io/realms/corporativo

LDAP_ADMIN_PASSWORD=CAMBIAR_24chars
LDAP_CONFIG_PASSWORD=CAMBIAR_24chars

SMTP_HOST=
SMTP_FROM=
SMTP_PORT=587
SMTP_SECURITY=starttls
SMTP_USERNAME=
SMTP_PASSWORD=
