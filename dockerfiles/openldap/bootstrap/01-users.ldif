member: uid=fran.parra,ou=people,dc=corp,dc=local

# ============================================================
# CUENTAS DE SERVICIO
# ============================================================

# --- svc-keycloak-bind: cuenta que usa Keycloak para leer el arbol ---
# (Keycloak consulta LDAP en modo READ_ONLY con esta cuenta)
dn: uid=svc-keycloak-bind,ou=services,dc=corp,dc=local
objectClass: inetOrgPerson
objectClass: organizationalPerson
objectClass: person
objectClass: top
uid: svc-keycloak-bind
cn: Keycloak Bind Service
sn: Service
givenName: Keycloak
displayName: Keycloak LDAP Federation Bind
description: Cuenta de servicio usada por Keycloak para la federation LDAP
userPassword: {SSHA}W8lWgQmfY/EvEGlaGtZXozG1dws+1yVw
title: Service Account
employeeType: service
