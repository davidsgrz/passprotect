# ============================================================
# PassProtect — Bootstrap LDIF
# ============================================================
# Estructura:
#   dc=corp,dc=local
#   ├── ou=people    (usuarios humanos)
#   ├── ou=groups    (grupos de autorizacion)
#   └── ou=services  (cuentas de servicio, p.ej. bind del LDAP federation)
#
# Password temporal para todos los usuarios: TempPass123!
# Hash SSHA generado con: slappasswd -h '{SSHA}' -s 'TempPass123!'
# (El hash abajo se valida con TempPass123! — cambialo en primera sesion)
#
# Keycloak hara el bind como admin con la password definida en
# la variable LDAP_ADMIN_PASSWORD (secret openldap-secrets).
# ============================================================

# ---------- OU: people ----------
dn: ou=people,dc=corp,dc=local
objectClass: organizationalUnit
objectClass: top
ou: people
description: Usuarios humanos de PassProtect

# ---------- OU: groups ----------
dn: ou=groups,dc=corp,dc=local
objectClass: organizationalUnit
objectClass: top
ou: groups
description: Grupos de autorizacion

# ---------- OU: services ----------
dn: ou=services,dc=corp,dc=local
objectClass: organizationalUnit
objectClass: top
ou: services
description: Cuentas de servicio (bind DNs)

# ============================================================
# USUARIOS
# ============================================================

