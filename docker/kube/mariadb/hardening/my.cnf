[mysqld]
# ── Proteccion contra SQL Injection ──
sql_mode=STRICT_TRANS_TABLES,ERROR_FOR_DIVISION_BY_ZERO,NO_ENGINE_SUBSTITUTION,NO_ZERO_DATE,NO_ZERO_IN_DATE,NO_AUTO_VALUE_ON_ZERO

# Deshabilitar LOAD DATA LOCAL (previene file read via SQLi)
local_infile=0

# Deshabilitar FEDERATED engine (previene SSRF via SQL)
skip_federated

# ── Limites anti-DoS ──
max_connections=200
max_user_connections=50
max_connect_errors=5
max_allowed_packet=64M

# Timeout agresivo para prevenir conexiones colgadas
wait_timeout=120
interactive_timeout=120
connect_timeout=10

# ── Query logging (para auditoria de SQLi attempts) ──
general_log=1
general_log_file=/var/log/mysql/general.log
log_warnings=2
log_error=/var/log/mysql/error.log

# ── Slow query log (detectar queries sospechosas) ──
slow_query_log=1
slow_query_log_file=/var/log/mysql/slow.log
long_query_time=1

# ── Seguridad general ──
skip_symbolic_links
secure_file_priv=/var/lib/mysql-files
local-infile=0

# Bind solo a interfaz interna
bind-address=0.0.0.0

# ── TLS ──
# require_secure_transport=ON  # Descomentar cuando haya certs

# ── Charset UTF8MB4 (evita bugs de encoding que facilitan SQLi) ──
character-set-server=utf8mb4
collation-server=utf8mb4_unicode_ci

[mysql]
default-character-set=utf8mb4
local-infile=0

[client]
default-character-set=utf8mb4
